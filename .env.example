# ============================================
# .env.example — HR System Rev.5
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ⚠️  ห้ามใส่ค่าจริงในไฟล์นี้ — ไฟล์นี้ push GitHub ได้
# ============================================

# --- Anthropic Claude API ---
# สร้าง API Key ได้ที่: https://console.anthropic.com
VITE_CLAUDE_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# --- Firebase Configuration ---
# ดูค่าได้ที่: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# --- Security ---
# PIN สำหรับ Admin (ห้ามใช้ค่าจริงในไฟล์นี้!)
VITE_SECURE_PIN=YOUR_PIN_HERE
